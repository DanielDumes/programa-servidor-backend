# Configuración del servidor
PORT=5000
SECRET_KEY=dev-secret-key-ilo-dashboard

# Base de Datos (MongoDB)
MONGO_URI=mongodb://localhost:27017
DB_NAME=ilo_monitor

# Configuración de monitoreo
POLL_INTERVAL=15
HISTORY_SNAPSHOT_INTERVAL=3600
ILO_TIMEOUT=5

# Logs
LOG_FILE=monitor.log
LOG_LEVEL=INFO

# Zona Horaria (Offset en horas, ej -5 para Ecuador)
TIMEZONE_OFFSET=-5
